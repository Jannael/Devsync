---
import { getTranslation } from '@/i18n/translation'
import { getRelativeLocaleUrl } from 'astro:i18n'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)

interface Template {
  name: string
  owner: string
  repoName: string
  repo: string
  preview: string
}

const featuredTemplates: Template[] = [
  {
    name: 'Devsync Template',
    owner: 'jannael',
    repoName: 'devsync-default-template',
    repo: 'https://github.com/jannael/devsync-default-template',
    preview: 'https://preview.devsync.work',
  },
  {
    name: 'Asciifolio',
    owner: 'jannael',
    repoName: 'asciifolio',
    repo: 'https://github.com/jannael/asciifolio',
    preview: 'https://asciifolio.pages.dev',
  },
]
---

<section
  id="templates-section"
  class="templates relative flex flex-col items-center justify-center overflow-hidden px-4 py-16 sm:px-6 sm:py-24"
  aria-labelledby="templates-title"
>
  <!-- Radial glow -->
  <div
    class="h-75 w-75 sm:h-150 sm:w-150 pointer-events-none absolute left-1/2 top-1/3 z-0 -translate-x-1/2 -translate-y-1/2 opacity-[0.04] blur-[80px] dark:opacity-[0.06]"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 flex w-full max-w-5xl flex-col items-center">
    <!-- Section header -->
    <div class="mb-12 flex flex-col items-center text-center sm:mb-16">
      <h2
        id="templates-title"
        class="templates-title text-text mb-4 text-2xl font-semibold tracking-tight sm:text-3xl md:text-4xl"
      >
        {t['Beautiful by Default']}
      </h2>
      <p class="templates-subtitle text-text-secondary mx-auto max-w-xl text-base sm:text-lg">
        {t['templates description']}
      </p>
    </div>

    <!-- Templates grid -->
    <div class="templates-grid grid w-full grid-cols-1 gap-6 sm:grid-cols-2 lg:gap-8">
      {
        featuredTemplates.map((template, index) => {
          const lightPoster = `https://raw.githubusercontent.com/${template.owner}/${template.repoName}/main/public/poster-light-mode.webp`
          const darkPoster = `https://raw.githubusercontent.com/${template.owner}/${template.repoName}/main/public/poster-dark-mode.webp`

          return (
            <div
              class="template-card border-border bg-surface group flex flex-col overflow-hidden rounded-xl border shadow-sm transition-all duration-300"
              style={`animation-delay: ${0.15 * index}s`}
            >
              <a
                href={template.preview}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-surface-sunken aspect-1200/630 relative overflow-hidden"
              >
                <img
                  class="block h-full w-full object-contain dark:hidden"
                  src={lightPoster}
                  alt={`${template.name} poster`}
                  loading="lazy"
                />
                <img
                  class="hidden h-full w-full object-contain dark:block"
                  src={darkPoster}
                  alt={`${template.name} poster`}
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/0 transition-colors duration-300 group-hover:bg-black/10" />
              </a>

              <div class="flex flex-col gap-4 p-5 sm:p-6">
                <h3 class="text-text text-lg font-semibold sm:text-xl">{template.name}</h3>

                <div class="mt-auto flex flex-wrap gap-3">
                  <a
                    href={template.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border-border text-text-secondary hover:border-accent hover:text-accent inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-semibold transition-all duration-200 hover:scale-105 active:scale-95"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                      <path d="M9 18c-4.51 2-5-2-7-2" />
                    </svg>
                    {t['View Repository']}
                  </a>
                  <a
                    href={template.preview}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border-accent/30 text-accent hover:bg-accent inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-semibold transition-all duration-200 hover:scale-105 hover:text-white active:scale-95"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                    {t['Live Preview']}
                  </a>
                </div>
              </div>
            </div>
          )
        })
      }
    </div>

    <!-- Bottom link -->
    <a
      href={getRelativeLocaleUrl(lang, '/create-template/')}
      class="templates-link text-accent hover:text-accent-hover mt-12 inline-flex items-center gap-2 text-sm font-semibold transition-all duration-200 hover:scale-105 sm:text-base"
    >
      {t['Create your own']}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </a>
  </div>
</section>

<script>
  function setupObserver() {
    const section = document.getElementById('templates-section')
    if (!section) return
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('animate')
            observer.disconnect()
          }
        })
      },
      { threshold: 0.1 }
    )
    observer.observe(section)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupObserver)
  } else {
    setupObserver()
  }
</script>

<style>
  /* ── Entrance animations ── */
  .templates-title {
    opacity: 0;
    transform: translateY(20px);
  }

  .templates.animate .templates-title {
    animation: templates-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .templates-subtitle {
    opacity: 0;
    transform: translateY(20px);
  }

  .templates.animate .templates-subtitle {
    animation: templates-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
  }

  .template-card {
    opacity: 0;
    transform: translateY(20px);
  }

  .templates.animate .template-card {
    animation: templates-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .templates-link {
    opacity: 0;
    transform: translateY(10px);
  }

  .templates.animate .templates-link {
    animation: templates-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  @keyframes templates-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
