---
import { getTranslation } from '@/i18n/translation'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)
---

<section
	id="badge-builder-section"
	class="badge-builder relative flex flex-col items-center justify-center overflow-hidden px-4 py-16 sm:px-6 sm:py-24"
	aria-labelledby="badge-builder-title"
>
	<div
		class="pointer-events-none absolute top-1/3 left-1/2 z-0 h-75 w-75 -translate-x-1/2 -translate-y-1/2 opacity-[0.04] blur-[80px] sm:h-150 sm:w-150 dark:opacity-[0.06]"
		aria-hidden="true"
	>
	</div>

	<div class="relative z-10 flex w-full max-w-5xl flex-col items-center gap-12 lg:flex-row lg:items-start lg:gap-16">
		<div class="flex w-full max-w-lg flex-col items-center text-center lg:items-start lg:text-left">
			<h2 id="badge-builder-title" class="badge-builder-title text-text mb-4 text-2xl font-semibold tracking-tight sm:text-3xl md:text-4xl">
				{t['Badge Builder']}
			</h2>
			<p class="badge-builder-subtitle text-text-secondary mb-8 text-base sm:text-lg">
				{t['badge builder description']}
			</p>

			<ul class="badge-builder-list space-y-4">
				<li class="flex items-start gap-3 text-left">
					<svg
						class="text-accent mt-0.5 shrink-0"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<circle cx="12" cy="12" r="10"></circle>
						<circle cx="12" cy="12" r="4"></circle>
						<line x1="4.93" y1="4.93" x2="9.17" y2="9.17"></line>
						<line x1="14.83" y1="14.83" x2="19.07" y2="19.07"></line>
						<line x1="4.93" y1="19.07" x2="9.17" y2="14.83"></line>
						<line x1="14.83" y1="9.17" x2="19.07" y2="4.93"></line>
					</svg>
					<div>
						<span class="text-text font-medium">{t['Custom Colors']}</span>
						<p class="text-text-secondary text-sm">{t['custom colors description']}</p>
					</div>
				</li>
				<li class="flex items-start gap-3 text-left">
					<svg
						class="text-accent mt-0.5 shrink-0"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect x="3" y="3" width="7" height="7"></rect>
						<rect x="14" y="3" width="7" height="7"></rect>
						<rect x="14" y="14" width="7" height="7"></rect>
						<rect x="3" y="14" width="7" height="7"></rect>
					</svg>
					<div>
						<span class="text-text font-medium">{t['Multiple Styles']}</span>
						<p class="text-text-secondary text-sm">{t['multiple styles description']}</p>
					</div>
				</li>
				<li class="flex items-start gap-3 text-left">
					<svg
						class="text-accent mt-0.5 shrink-0"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<polyline points="16 18 22 12 16 6"></polyline>
						<polyline points="8 6 2 12 8 18"></polyline>
					</svg>
					<div>
						<span class="text-text font-medium">{t['Logo Integration']}</span>
						<p class="text-text-secondary text-sm">{t['logo integration description']}</p>
					</div>
				</li>
				<li class="flex items-start gap-3 text-left">
					<svg
						class="text-accent mt-0.5 shrink-0"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
						<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
					</svg>
					<div>
						<span class="text-text font-medium">{t['Copy to Clipboard']}</span>
						<p class="text-text-secondary text-sm">{t['copy to clipboard description']}</p>
					</div>
				</li>
			</ul>

			<a
				href="/badge-builder"
				class="badge-builder-cta border-accent/30 text-accent hover:bg-accent mt-8 inline-flex h-12 items-center gap-2.5 rounded-xl border px-7 text-sm font-semibold transition-all duration-200 hover:scale-105 hover:text-white active:scale-95 sm:text-base"
			>
				{t['Try It Now']}
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M5 12h14"></path>
					<path d="m12 5 7 7-7 7"></path>
				</svg>
			</a>
		</div>

		<div class="badge-builder-preview flex w-full items-center justify-center lg:flex-1 lg:self-center">
			<div class="border-border bg-surface flex flex-col items-center gap-5 rounded-xl border p-6 shadow-sm">
				<div class="border-border/70 inline-flex rounded-lg border">
					<button type="button" id="badge-copy-btn" class="group relative cursor-pointer p-3 leading-0" aria-label="Copy badge markdown">
						<img
							id="badge-preview-img"
							src="https://img.shields.io/badge/DEVSYNC-4ade80.svg?style=for-the-badge&logo=typescript&logoColor=ffffff"
							alt="DEVSYNC"
							class="h-9 sm:h-10"
							draggable="false"
							decoding="async"
						/>
						<span
							id="badge-copied-toast"
							class="bg-accent text-accent-foreground pointer-events-none absolute -top-5 left-1/2 z-10 -translate-x-1/2 rounded-md px-2 py-1 text-xs font-medium opacity-0 shadow-sm transition-opacity duration-200"
						>
							Copied!
						</span>
					</button>
				</div>

				<div class="flex items-center gap-4">
					<div class="flex items-center gap-2">
						<label for="mini-color" class="text-text-muted text-xs font-medium">Color</label>
						<input id="mini-color" type="color" value="#4ade80" class="border-border h-8 w-8 cursor-pointer rounded border p-0.5" />
					</div>
					<div class="flex items-center gap-2">
						<label for="mini-style" class="text-text-muted text-xs font-medium">Style</label>
						<select id="mini-style" class="border-input-border bg-input-bg text-input-text h-8 rounded border px-2 text-xs outline-none">
							<option value="flat">Flat</option>
							<option value="flat-square">Square</option>
							<option value="plastic">Plastic</option>
							<option value="for-the-badge" selected>Badge</option>
							<option value="social">Social</option>
						</select>
					</div>
					<div class="flex items-center gap-2">
						<label for="mini-logo" class="text-text-muted text-xs font-medium">Logo</label>
						<select id="mini-logo" class="border-input-border bg-input-bg text-input-text h-8 rounded border px-2 text-xs outline-none">
							<option value="">None</option>
							<option value="typescript" selected>TS</option>
							<option value="github">GitHub</option>
							<option value="docker">Docker</option>
						</select>
					</div>
				</div>
			</div>
		</div>
	</div>

	<script>
		const btn = document.getElementById('badge-copy-btn')
		const toast = document.getElementById('badge-copied-toast')
		const img = document.getElementById('badge-preview-img') as HTMLImageElement
		const colorInput = document.getElementById('mini-color') as HTMLInputElement
		const styleInput = document.getElementById('mini-style') as HTMLSelectElement
		const logoInput = document.getElementById('mini-logo') as HTMLSelectElement

		function buildUrl() {
			const color = colorInput.value.replace('#', '')
			const style = styleInput.value
			const logo = logoInput.value
			return `https://img.shields.io/badge/DEVSYNC-${color}.svg?style=${style}${logo ? `&logo=${logo}&logoColor=ffffff` : ''}`
		}

		function updateBadge() {
			if (img) img.src = buildUrl()
		}

		colorInput?.addEventListener('input', updateBadge)
		styleInput?.addEventListener('change', updateBadge)
		logoInput?.addEventListener('change', updateBadge)

		btn?.addEventListener('click', async () => {
			const src = img?.getAttribute('src')
			const alt = img?.getAttribute('alt') ?? 'DEVSYNC'
			if (!src) return

			const md = `![${alt}](${src})`

			try {
				await navigator.clipboard.writeText(md)
			} catch {
				const ta = document.createElement('textarea')
				ta.value = md
				ta.style.position = 'fixed'
				ta.style.opacity = '0'
				document.body.appendChild(ta)
				ta.select()
				document.execCommand('copy')
				document.body.removeChild(ta)
			}

			toast?.classList.remove('opacity-0')
			toast?.classList.add('opacity-100')
			setTimeout(() => {
				toast?.classList.remove('opacity-100')
				toast?.classList.add('opacity-0')
			}, 1500)
		})
	</script>

	<script>
		function setupObserver() {
			const section = document.getElementById('badge-builder-section')
			if (!section) return
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							section.classList.add('animate')
							observer.disconnect()
						}
					})
				},
				{ threshold: 0.1 },
			)
			observer.observe(section)
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', setupObserver)
		} else {
			setupObserver()
		}
	</script>
</section>

<style>
	.badge-builder-title {
		opacity: 0;
		transform: translateY(20px);
	}

	.badge-builder.animate .badge-builder-title {
		animation: bb-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	.badge-builder-subtitle {
		opacity: 0;
		transform: translateY(20px);
	}

	.badge-builder.animate .badge-builder-subtitle {
		animation: bb-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
	}

	.badge-builder-list {
		opacity: 0;
		transform: translateY(20px);
	}

	.badge-builder.animate .badge-builder-list {
		animation: bb-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
	}

	.badge-builder-cta {
		opacity: 0;
		transform: translateY(10px);
	}

	.badge-builder.animate .badge-builder-cta {
		animation: bb-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
	}

	.badge-builder-preview {
		opacity: 0;
		transform: translateY(20px) scale(0.95);
	}

	.badge-builder.animate .badge-builder-preview {
		animation: bb-fade-up-scale 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
	}

	@keyframes bb-fade-up {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes bb-fade-up-scale {
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}
</style>
