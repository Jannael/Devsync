---
import { getTranslation } from '@/i18n/translation'
import { getRelativeLocaleUrl } from 'astro:i18n'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)
---

<section
	id="get-started-section"
	class="get-started relative flex flex-col items-center justify-center overflow-hidden px-4 py-16 sm:px-6 sm:py-24"
	aria-labelledby="get-started-title"
>
	<div class="relative z-10 flex w-full max-w-5xl flex-col items-center">
		<div class="mb-12 flex flex-col items-center text-center sm:mb-16">
			<h2 id="get-started-title" class="get-started-title text-text mb-4 text-2xl font-semibold tracking-tight sm:text-3xl md:text-4xl">
				{t['Choose Your Path']}
			</h2>
			<p class="get-started-subtitle text-text-secondary mx-auto max-w-xl text-base sm:text-lg">
				{t['get started description']}
			</p>
		</div>

		<div class="get-started-grid grid w-full grid-cols-1 gap-8 lg:grid-cols-3">
			<div
				class="get-started-card border-border bg-surface group flex flex-col rounded-2xl border p-8 shadow-sm transition-all duration-300 hover:shadow-md"
			>
				<div class="bg-accent/10 mb-6 inline-flex h-12 w-12 items-center justify-center rounded-lg">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="text-accent"
					>
						<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
						></path>
						<polyline points="7.5 4.21 12 6.81 16.5 4.21"></polyline>
						<polyline points="7.5 19.79 7.5 14.6 3 12"></polyline>
						<polyline points="21 12 16.5 14.6 16.5 19.79"></polyline>
						<polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
						<line x1="12" y1="22.08" x2="12" y2="12"></line>
					</svg>
				</div>
				<h3 class="text-text mb-3 text-xl font-semibold">{t['Use a Template']}</h3>
				<p class="text-text-secondary mb-6 flex-1 text-sm">
					{t['use template description']}
				</p>
				<a
					href="#templates-section"
					class="border-accent/30 text-accent hover:bg-accent inline-flex h-10 items-center justify-center gap-2 rounded-lg border px-5 text-sm font-semibold transition-all duration-200 hover:scale-105 hover:text-white active:scale-95"
				>
					{t['Browse Templates']}
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M5 12h14"></path>
						<path d="m12 5 7 7-7 7"></path>
					</svg>
				</a>
			</div>

			<div
				class="get-started-card border-border bg-surface group flex flex-col rounded-2xl border p-8 shadow-sm transition-all duration-300 hover:shadow-md"
			>
				<div class="bg-accent/10 mb-6 inline-flex h-12 w-12 items-center justify-center rounded-lg">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="text-accent"
					>
						<path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
						<path d="M18.375 2.625a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path>
					</svg>
				</div>
				<h3 class="text-text mb-3 text-xl font-semibold">{t['Create from Scratch']}</h3>
				<p class="text-text-secondary mb-6 flex-1 text-sm">
					{t['create from scratch description']}
				</p>
				<a
					href={getRelativeLocaleUrl(lang, '/create-template/')}
					class="border-accent/30 text-accent hover:bg-accent inline-flex h-10 items-center justify-center gap-2 rounded-lg border px-5 text-sm font-semibold transition-all duration-200 hover:scale-105 hover:text-white active:scale-95"
				>
					{t['Learn How']}
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M5 12h14"></path>
						<path d="m12 5 7 7-7 7"></path>
					</svg>
				</a>
			</div>

			<div
				class="get-started-card border-border bg-surface group flex flex-col rounded-2xl border p-8 shadow-sm transition-all duration-300 hover:shadow-md"
			>
				<div class="bg-accent/10 mb-6 inline-flex h-12 w-12 items-center justify-center rounded-lg">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="text-accent"
					>
						<path d="M12 8V4H8"></path>
						<rect width="16" height="12" x="4" y="8" rx="2"></rect>
						<path d="M2 14h2"></path>
						<path d="M20 14h2"></path>
						<path d="M15 13v2"></path>
						<path d="M9 13v2"></path>
					</svg>
				</div>
				<h3 class="text-text mb-3 text-xl font-semibold">{t['Use with AI']}</h3>
				<p class="text-text-secondary mb-6 flex-1 text-sm">
					{t['use with ai description']}
				</p>
				<a
					href={getRelativeLocaleUrl(lang, '/create-template/')}
					class="border-accent/30 text-accent hover:bg-accent inline-flex h-10 items-center justify-center gap-2 rounded-lg border px-5 text-sm font-semibold transition-all duration-200 hover:scale-105 hover:text-white active:scale-95"
				>
					{t['View Skill']}
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M5 12h14"></path>
						<path d="m12 5 7 7-7 7"></path>
					</svg>
				</a>
			</div>
		</div>
	</div>

	<script>
		function setupObserver() {
			const section = document.getElementById('get-started-section')
			if (!section) return
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							section.classList.add('animate')
							observer.disconnect()
						}
					})
				},
				{ threshold: 0.1 },
			)
			observer.observe(section)
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', setupObserver)
		} else {
			setupObserver()
		}
	</script>

	<style>
		.get-started-title {
			opacity: 0;
			transform: translateY(20px);
		}

		.get-started.animate .get-started-title {
			animation: get-started-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		}

		.get-started-subtitle {
			opacity: 0;
			transform: translateY(20px);
		}

		.get-started.animate .get-started-subtitle {
			animation: get-started-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
		}

		.get-started-card {
			opacity: 0;
			transform: translateY(20px);
		}

		.get-started.animate .get-started-card:nth-child(1) {
			animation: get-started-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
		}

		.get-started.animate .get-started-card:nth-child(2) {
			animation: get-started-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.45s forwards;
		}

		.get-started.animate .get-started-card:nth-child(3) {
			animation: get-started-fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
		}

		@keyframes get-started-fade-up {
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	</style>
</section>
