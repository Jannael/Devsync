---
import astroRaw from '@/icons/astro.svg?raw'
import tailwindRaw from '@/icons/tailwindcss.svg?raw'
import typescriptRaw from '@/icons/typescript.svg?raw'

export interface Template {
	name: string
	owner: string
	repoName: string
	repo: string
	preview: string
	technologies: string[]
	command: string
}

export interface Props {
	template: Template
	index: number
	viewRepositoryLabel: string
	livePreviewLabel: string
}

const { template, index, viewRepositoryLabel, livePreviewLabel } = Astro.props

const lightPoster = `https://raw.githubusercontent.com/${template.owner}/${template.repoName}/main/public/poster-light-mode.webp`
const darkPoster = `https://raw.githubusercontent.com/${template.owner}/${template.repoName}/main/public/poster-dark-mode.webp`

const techConfig: Record<string, { svg: string; iconBg?: string }> = {
	Astro: { svg: astroRaw, iconBg: 'bg-[#17191E] rounded-[3px] p-[2px]' },
	'Tailwind CSS': { svg: tailwindRaw },
	TypeScript: { svg: typescriptRaw },
}
---

<div
	class="template-card border-border bg-surface group flex h-full flex-col overflow-hidden rounded-2xl border shadow-sm transition-all duration-300"
	style={`animation-delay: ${0.15 * index}s`}
>
	<a href={template.preview} target="_blank" rel="noopener noreferrer" class="bg-surface-sunken relative aspect-1200/630 min-h-40 overflow-hidden">
		<img class="block h-full w-full object-contain dark:hidden" src={lightPoster} alt={`${template.name} poster`} loading="lazy" />
		<img class="hidden h-full w-full object-contain dark:block" src={darkPoster} alt={`${template.name} poster`} loading="lazy" />
		<div class="absolute inset-0 bg-black/0 transition-colors duration-300 group-hover:bg-black/10"></div>
	</a>

	<div class="flex flex-1 flex-col gap-5 p-6">
		<h3 class="text-text mt-4 text-xl font-semibold">{template.name}</h3>

		<div class="flex flex-wrap gap-2">
			{
				template.technologies.map((tech) => {
					const config = techConfig[tech]
					return (
						<span class="border-border bg-surface-sunken text-text-secondary inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-medium">
							{config?.svg && (
								<span
									class={`h-3.5 w-3.5 shrink-0 [&>svg]:h-full [&>svg]:w-full ${config.iconBg ? ` ${config.iconBg}` : ''}`}
									aria-hidden="true"
									set:html={config.svg}
								/>
							)}
							{tech}
						</span>
					)
				})
			}
		</div>

		<div class="template-command border-border bg-surface-sunken mb-4 flex items-center gap-3 rounded-lg border px-4 py-3">
			<code class="text-text-secondary min-w-0 flex-1 truncate font-mono text-[0.85rem]">
				$ {template.command}
			</code>
			<button
				type="button"
				class="template-copy-btn text-text-secondary hover:text-accent relative ml-auto flex h-10 w-5 shrink-0 cursor-pointer items-center justify-center rounded p-1 transition-colors duration-200"
				aria-label="Copy command"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="copy-icon absolute inset-0 my-auto transition-opacity duration-200"
				>
					<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
					<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
				</svg>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					class="check-icon text-accent absolute inset-0 my-auto opacity-0 transition-opacity duration-200"
				>
					<polyline points="20 6 9 17 4 12"></polyline>
				</svg>
			</button>
		</div>

		<div class="mt-auto flex flex-wrap gap-3">
			<a
				href={template.repo}
				target="_blank"
				rel="noopener noreferrer"
				class="border-border text-text-secondary hover:border-accent hover:text-accent inline-flex h-10 items-center gap-2 rounded-lg border px-5 py-[0.6rem] text-sm font-semibold transition-all duration-200 hover:scale-105 active:scale-95"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path
						d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
					></path>
					<path d="M9 18c-4.51 2-5-2-7-2"></path>
				</svg>
				{viewRepositoryLabel}
			</a>
			<a
				href={template.preview}
				target="_blank"
				rel="noopener noreferrer"
				class="border-accent/30 text-accent hover:bg-accent inline-flex h-10 items-center gap-2 rounded-lg border px-5 py-[0.6rem] text-sm font-semibold transition-all duration-200 hover:scale-105 hover:text-white active:scale-95"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
					<polyline points="15 3 21 3 21 9"></polyline>
					<line x1="10" y1="14" x2="21" y2="3"></line>
				</svg>
				{livePreviewLabel}
			</a>
		</div>
	</div>
</div>
