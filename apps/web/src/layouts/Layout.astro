---
import '@/styles/global.css'
import '@fontsource-variable/bitter/wght.css'
import MouseASCIITrail from '@/components/mouse-ascii-trail.astro'

interface Props {
	title?: string
	description?: string
}

const {
	title = 'Devsync - Everything you need to get a job in seconds',
	description = 'Devsync is tool to create your resume, portfolio, academics history, github profile and more in seconds from one file.',
} = Astro.props

const site = Astro.site ?? new URL('https://devsync.work')
const canonicalUrl = new URL(Astro.url.pathname, site).toString()
const ogImageUrl = new URL('/og.png', site).toString()
const ogImageAlt = 'Devsync preview'
const homeUrl = new URL('/', site).toString()
const logoUrl = new URL('/logo-512-white.webp', site).toString()
const organizationId = `${homeUrl}#organization`
const websiteId = `${homeUrl}#website`
const softwareAppId = `${homeUrl}#software-application`

const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': organizationId,
			name: 'Devsync ',
			url: homeUrl,
			logo: {
				'@type': 'ImageObject',
				url: logoUrl,
			},
			sameAs: ['https://github.com/jannael/devsync', 'https://github.com/jannael', 'https://www.linkedin.com/in/jannael-orlando-44604a349'],
		},
		{
			'@type': 'WebSite',
			'@id': websiteId,
			url: homeUrl,
			name: 'Devsync',
			description,
			inLanguage: 'en-US',
			publisher: {
				'@id': organizationId,
			},
		},
		{
			'@type': 'SoftwareApplication',
			'@id': softwareAppId,
			name: 'Devsync',
			description,
			url: canonicalUrl,
			image: ogImageUrl,
			applicationCategory: 'DeveloperApplication',
			operatingSystem: 'Windows, macOS, Linux',
			offers: {
				'@type': 'Offer',
				price: '0',
				priceCurrency: 'USD',
			},
			publisher: {
				'@id': organizationId,
			},
		},
	],
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" href="/favicon-32x32.svg" sizes="32x32" type="image/svg+xml" />
		<link rel="icon" href="/favicon-16x16.svg" sizes="16x16" type="image/svg+xml" />
		<link rel="icon" href="/logo-192-black.webp" sizes="192x192" type="image/webp" media="(prefers-color-scheme: light)" />
		<link rel="icon" href="/logo-192-white.webp" sizes="192x192" type="image/webp" media="(prefers-color-scheme: dark)" />
		<link rel="apple-touch-icon" href="/apple-touch-icon-black.webp" media="(prefers-color-scheme: light)" />
		<link rel="apple-touch-icon" href="/apple-touch-icon-white.webp" media="(prefers-color-scheme: dark)" />
		<link rel="apple-touch-icon" href="/apple-touch-icon-white.webp" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta name="mobile-web-app-capable" content="no" />
		<meta name="apple-mobile-web-app-capable" content="no" />

		<meta name="theme-color" content="#0a0a0a" />
		<meta name="robots" content="index, follow" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta property="og:site_name" content="Devsync" />
		<meta property="og:locale" content="en_US" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@JannaelCode" />
		<meta name="twitter:creator" content="@JannaelCode" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<script>
			const matchMedia = window.matchMedia('(prefers-color-scheme: dark)')
			const hasStoredTheme = () => localStorage.getItem('theme') !== null
			const getTheme = () => localStorage.getItem('theme') ?? (matchMedia.matches ? 'dark' : 'light')
			const applyTheme = () => {
				document.documentElement.classList.toggle('dark', getTheme() === 'dark')
			}

			applyTheme()

			matchMedia.addEventListener('change', () => {
				if (!hasStoredTheme()) {
					applyTheme()
				}
			})
		</script>
	</head>
	<body class="bg-bg overflow-x-hidden">
		<slot />
		<MouseASCIITrail />
	</body>

	<style is:global>
		body {
			font-family: 'Bitter Variable', sans-serif;
		}
	</style>
</html>
