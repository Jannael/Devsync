---
import Layout from '@/layouts/Layout.astro'
import BackgroundGrid from '@/components/background-grid.astro'
import Badge from '@/components/badge.astro'
import GitHub from '@/assets/github-svg.astro'
import LanguageSelector from '@/components/language-selector.astro'
import NavTheme from '@/components/nav-theme.astro'
import { getTranslation } from '@/i18n/translation'

const lang = Astro.currentLocale ?? 'en'
const t = getTranslation(lang)
const b = t['builder']
---


<Layout
  title={b['title']}
  description={b['description']}
>
  <header
    class="nav-bar absolute top-0 z-40 m-auto flex w-full max-w-5xl items-center justify-end gap-3 px-4 pt-4 sm:gap-5 sm:px-6 sm:pt-5"
  >
    <div
      class="nav-bar-inner border-border/30 bg-surface/80 flex items-center gap-1 rounded-full border px-3 py-2 shadow-sm backdrop-blur-md sm:gap-2 sm:px-4 sm:py-2.5 dark:border-white/10 dark:shadow-md"
    >
      <a
        href="https://github.com/jannael/devsync"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-item text-text-secondary hover:text-accent inline-flex items-center justify-center rounded-full p-2 transition-colors duration-200"
        aria-label={b['viewSource']}
      >
        <GitHub />
      </a>
      <div class="nav-divider bg-border/30 h-4 w-px" aria-hidden="true"></div>
      <LanguageSelector />
      <div class="nav-divider bg-border/30 h-4 w-px" aria-hidden="true"></div>
      <NavTheme />
    </div>
  </header>
  <BackgroundGrid />

  <!-- Radial glow behind ASCII -->
  <div
    class="hero-glow pointer-events-none absolute top-1/3 left-1/2 z-0 h-75 w-75 -translate-x-1/2 -translate-y-1/2 opacity-[0.04] blur-[80px] sm:h-75 sm:w-150 dark:opacity-[0.06]"
    aria-hidden="true"
  >
  </div>

  <div class="relative flex min-h-screen w-full items-center justify-center">
    <main class="flex w-full max-w-6xl gap-10">
      <!-- ── Form ── -->
      <section class="w-1/3" aria-label={b['formLabel']}>
        <form id="badge-form" class="space-y-5" autocomplete="off">
          <!-- Label -->
          <div>
            <label for="input-label" class="text-text mb-1.5 block text-sm font-medium">
              {b['label']}
            </label>
            <input
              id="input-label"
              type="text"
              value=""
              placeholder={b['labelPlaceholder']}
              class="border-border bg-input-bg text-input-text placeholder:text-input-placeholder focus:border-border-focus focus:ring-ring w-full rounded-lg border px-3.5 py-2.5 text-sm transition-colors outline-none focus:ring-[3px]"
            />
          </div>

          <!-- Message -->
          <div>
            <label for="input-message" class="text-text mb-1.5 block text-sm font-medium">
              {b['message']}
            </label>
            <input
              id="input-message"
              type="text"
              value=""
              placeholder={b['messagePlaceholder']}
              class="border-border bg-input-bg text-input-text placeholder:text-input-placeholder focus:border-border-focus focus:ring-ring w-full rounded-lg border px-3.5 py-2.5 text-sm transition-colors outline-none focus:ring-[3px]"
            />
          </div>

          <!-- Color -->
          <div class="flex gap-5">
            <div class="flex flex-col">
              <label for="input-color" class="text-text mb-1.5 block text-sm font-medium">
                {b['color']}
              </label>
              <input
                id="input-color-picker"
                type="color"
                value="#4ade80"
                class="border-border h-11 w-11 shrink-0 cursor-pointer rounded-lg border bg-transparent p-1"
              />
            </div>
            <div>
              <label for="input-logo-color" class="text-text mb-1.5 block text-sm font-medium">
                {b['logo']}
              </label>
              <div class="flex gap-3">
                <input
                  id="input-logo-color-picker"
                  type="color"
                  value="#ffffff"
                  class="border-border h-11 w-11 shrink-0 cursor-pointer rounded-lg border bg-transparent p-1"
                />
              </div>
            </div>
            <div class="flex flex-col">
              <label for="input-style" class="text-text mb-1.5 block text-sm font-medium">
                {b['style']}
              </label>
              <select
                id="input-style"
                class="border-border bg-input-bg text-input-text focus:border-border-focus focus:ring-ring h-full w-full rounded-lg border px-3.5 text-sm transition-colors outline-none focus:ring-[3px]"
              >
                <option value="flat">{b['styleFlat']}</option>
                <option value="flat-square">{b['styleFlatSquare']}</option>
                <option value="plastic">{b['stylePlastic']}</option>
                <option value="for-the-badge">{b['styleForTheBadge']}</option>
                <option value="social">{b['styleSocial']}</option>
              </select>
            </div>
          </div>

          <!-- Style -->

          <!-- Divider -->
          <div class="border-divider/50 border-t pt-5">
            <p class="text-text-secondary mb-4 text-xl uppercase">{b['optional']}</p>

            <!-- Logo -->
            <div class="mb-5">
              <label for="input-logo" class="text-text mb-1.5 block text-sm font-medium">
                {b['logo']}
              </label>
              <input
                id="input-logo"
                type="text"
                placeholder={b['logoPlaceholder']}
                class="border-border bg-input-bg text-input-text placeholder:text-input-placeholder focus:border-border-focus focus:ring-ring w-full rounded-lg border px-3.5 py-2.5 text-sm transition-colors outline-none focus:ring-[3px]"
              />
              <p class="text-text-muted mt-1 text-xs">
                {b['simpleIconsSlug']} <a
                  href="https://simpleicons.org"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-text-link hover:text-text-link-hover underline">{b['browseIcons']}</a
                >
              </p>
            </div>

            <!-- Logo Color -->
            <div class="mb-5"></div>
          </div>
        </form>
      </section>

      <section
        class="flex w-full flex-wrap content-start items-start justify-start gap-5 rounded-lg border p-5"
        aria-label={b['previewLabel']}
      >
        <!-- Preview -->
        <Badge label="" message="DEVSYNC" color="4ade80" style="flat" className="input-badge" />

        {/* --- DARK --- */}
        <Badge label="" message="DEVSYNC" color="000000" style="flat" />
        <Badge label="" message="DEVSYNC" color="0f172a" style="flat" />
        <Badge label="" message="DEVSYNC" color="0f172a" style="flat-square" />
        <Badge label="" message="DEVSYNC" color="0f172a" style="for-the-badge" />
        <Badge label="" message="DEVSYNC" color="0f172a" style="plastic" />

        {/* --- LIGHT --- */}
        <Badge label="" message="DEVSYNC" color="f8fafc" logoColor="000000" style="flat" />
        <Badge label="" message="DEVSYNC" color="f8fafc" logoColor="000000" style="flat-square" />
        <Badge label="" message="DEVSYNC" color="f8fafc" logoColor="000000" style="for-the-badge" />
        <Badge label="" message="DEVSYNC" color="f8fafc" logoColor="000000" style="plastic" />

        {/* --- GREEN (tu color base) --- */}
        <Badge label="" message="DEVSYNC" color="4ade80" style="flat" logoColor="0f172a" />
        <Badge label="" message="DEVSYNC" color="4ade80" style="flat-square" logoColor="0f172a" />
        <Badge label="" message="DEVSYNC" color="4ade80" style="for-the-badge" logoColor="0f172a" />
        <Badge label="" message="DEVSYNC" color="4ade80" style="plastic" logoColor="0f172a" />

        {/* --- BLUE --- */}
        <Badge label="" message="DEVSYNC" color="3b82f6" style="flat" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="3b82f6" style="flat-square" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="3b82f6" style="for-the-badge" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="3b82f6" style="plastic" logoColor="ffffff" />

        {/* --- PURPLE --- */}
        <Badge label="" message="DEVSYNC" color="7c3aed" style="flat" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="7c3aed" style="flat-square" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="7c3aed" style="for-the-badge" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="7c3aed" style="plastic" logoColor="ffffff" />

        {/* --- RED --- */}
        <Badge label="" message="DEVSYNC" color="ef4444" style="flat" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="ef4444" style="flat-square" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="ef4444" style="for-the-badge" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="ef4444" style="plastic" logoColor="ffffff" />

        {/* --- AMBER --- */}
        <Badge label="" message="DEVSYNC" color="f59e0b" style="flat" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="f59e0b" style="flat-square" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="f59e0b" style="for-the-badge" logoColor="ffffff" />
        <Badge label="" message="DEVSYNC" color="f59e0b" style="plastic" logoColor="ffffff" />

        {/* --- CON LABEL --- */}
        <Badge label="build" message="DEVSYNC" color="0f172a" style="flat" logoColor="4ade80" />
        <Badge label="build" message="DEVSYNC" color="4ade80" style="flat" logoColor="0f172a" />
        <Badge
          label="v1.0"
          message="DEVSYNC"
          color="7c3aed"
          style="for-the-badge"
          logoColor="ffffff"
        />
        <Badge
          label="v1.0"
          message="DEVSYNC"
          color="f59e0b"
          style="for-the-badge"
          logoColor="0f172a"
        />
      </section>
    </main>
  </div>
</Layout>

<script>
  const labelInput = document.getElementById('input-label') as HTMLInputElement
  const messageInput = document.getElementById('input-message') as HTMLInputElement
  const colorInput = document.getElementById('input-color-picker') as HTMLInputElement
  const styleInput = document.getElementById('input-style') as HTMLSelectElement
  const logoInput = document.getElementById('input-logo') as HTMLInputElement
  const logoColorInput = document.getElementById('input-logo-color-picker') as HTMLInputElement

  const specialBadge = document.querySelector('.input-badge') as HTMLImageElement
  const allBadges = document.querySelectorAll('.badge-copy-btn img') as NodeListOf<HTMLImageElement>

  const inputs = [colorInput, styleInput, logoColorInput]

  let logo = ''

  function debounce<T extends (...args: any[]) => void>(
    fn: T,
    ms: number
  ): (...args: Parameters<T>) => void {
    let timer: ReturnType<typeof setTimeout>
    return (...args) => {
      clearTimeout(timer)
      timer = setTimeout(() => fn(...args), ms)
    }
  }

  const refreshSpecial = () =>
    specialBadge.setAttribute('src', getBadgeUrl({ ...getInputValues() }))
  const refreshAll = () => {
    refreshSpecial()
    updateAllBadges()
  }

  const debouncedRefreshAll = debounce(refreshAll, 500)

  inputs.forEach((input) => {
    input.addEventListener('input', refreshSpecial)
    input.addEventListener('change', refreshSpecial)
  })

  labelInput.addEventListener('input', debouncedRefreshAll)

  logoInput.addEventListener('input', () => {
    logo = logoInput.value
    debouncedRefreshAll()
  })

  messageInput.addEventListener('input', () => {
    logo = messageInput.value
    debouncedRefreshAll()
  })

  function updateAllBadges() {
    allBadges.forEach((badge) => {
      const color = badge.getAttribute('data-color') ?? '000000'
      const style = badge.getAttribute('data-style') ?? 'flat'
      const logoColor = badge.getAttribute('data-logoColor') ?? 'ffffff'

      badge.setAttribute('src', getBadgeUrl({ ...getInputValues(), color, style, logoColor }))
    })
  }

  function getInputValues() {
    specialBadge.setAttribute('data-color', colorInput.value.replace('#', ''))
    specialBadge.setAttribute('data-style', styleInput.value)
    specialBadge.setAttribute('data-logoColor', logoColorInput.value.replace('#', ''))

    return {
      label: labelInput.value,
      message: messageInput.value || 'DEVSYNC',
      color: colorInput.value.replace('#', ''),
      style: styleInput.value,
      logo: logo.length > 1 ? logo : logoInput.value,
      logoColor: logoColorInput.value.replace('#', ''),
    }
  }

  function getBadgeUrl({
    label,
    message,
    color,
    style,
    logo,
    logoColor,
  }: {
    label?: string
    message: string
    color: string
    style: string
    logo?: string
    logoColor?: string
  }) {
    return `https://img.shields.io/badge/${label && label + '-'}${message}-${color}.svg?style=${style}${logo && `&logo=${logo}`}${logoColor && `&logoColor=${logoColor}`}`
  }
</script>
